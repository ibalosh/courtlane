{
  "name": "courtlane-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "Court reservation system",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "db:prepare": "yarn workspace @courtlane/db prisma:migrate:deploy",
    "db:reset": "yarn workspace @courtlane/db prisma migrate reset --force",
    "db:seed": "yarn workspace @courtlane/db prisma:seed",
    "web:start": "yarn workspace @courtlane/web start",
    "web:build": "yarn workspace @courtlane/web build",
    "web:test": "yarn workspace @courtlane/web test",
    "web:format": "yarn workspace @courtlane/web format",
    "api:start": "yarn workspace @courtlane/api start",
    "api:build": "yarn workspace @courtlane/api build",
    "api:test": "yarn workspace @courtlane/api test",
    "api:format": "yarn workspace @courtlane/api format",
    "start": "nx run-many -t start",
    "clean:dist": "rm -rf apps/api/dist apps/web/dist libs/contracts/dist libs/db/dist",
    "build": "yarn clean:dist && nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "all": "yarn build && yarn lint && yarn test && yarn format"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ibalosh/courtlane.git"
  },
  "keywords": [
    "court",
    "squash",
    "reservation",
    "slot",
    "booking"
  ],
  "author": "Igor Balos",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ibalosh/courtlane/issues"
  },
  "homepage": "https://github.com/ibalosh/courtlane#readme",
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/eslint": "22.6.5",
    "@nx/eslint-plugin": "22.6.5",
    "@nx/jest": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/node": "22.6.5",
    "@nx/react": "^22.6.5",
    "@nx/vite": "22.6.5",
    "@nx/vitest": "22.6.5",
    "@nx/web": "22.6.5",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "20.19.9",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "nx": "22.6.5",
    "prettier": "~3.6.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.0",
    "vitest": "~4.1.0"
  },
  "dependencies": {}
}
